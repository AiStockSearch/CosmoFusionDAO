{
  "name": "cosmofusion-dao-web",
  "version": "0.1.0",
  "private": true,
  "description": "COSMOFUSION DAO - Web Landing Application",
  "type": "module",
  "dependencies": {
    "@sentry/react": "^9.42.0",
    "@sentry/tracing": "^7.120.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^16.18.126",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/react-transition-group": "^4.4.12",
    "amplitude-js": "^8.21.9",
    "firebase": "^12.0.0",
    "framer-motion": "^12.23.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-helmet-async": "^2.0.5",
    "react-scripts": "5.0.1",
    "react-transition-group": "^4.4.5",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4",
    "yaml": "^2.8.0"
  },
  "scripts": {
    "start": "env $(cat .env | xargs) react-scripts start",
    "start:local": "env $(cat .env | xargs) serve -s build -l 3000",
    "build": "env $(cat .env | xargs) CI='' react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "predeploy": "npm run build",
    "prettier:fix": "prettier --write .",
    "deploy": "gh-pages -d build --repo https://github.com/AiStockSearch/CosmosAI.git",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test:coverage": "npm test -- --coverage --watchAll=false",
    "test:ci": "npm test -- --coverage --watchAll=false --ci",
    "test:debug": "npm test -- --verbose --no-coverage",
    "security:audit": "yarn audit --level high",
    "security:check": "node scripts/security-check.js",
    "bundle:analyze": "npm run build && npx webpack-bundle-analyzer build/static/js/*.js",
    "size:check": "size-limit",
    "cleanup:images": "node scripts/find-unused-images.js",
    "rename:images": "node scripts/rename-images.js",
    "update:imports": "node scripts/update-imports.js",
    "spell:check": "cspell \"**/*.{js,jsx,ts,tsx,md,json}\"",
    "spell:fix": "cspell \"**/*.{js,jsx,ts,tsx,md,json}\" --fix",
    "markdown:lint": "markdownlint \"**/*.md\"",
    "quality:check": "npm run lint && npm run type-check && npm run spell:check && npm run markdown:lint",
    "quality:fix": "npm run lint:fix && npm run prettier:fix && npm run spell:fix",
    "prepare": "husky install",
    "pre-commit": "lint-staged",
    "postinstall": "husky install"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.2.1",
    "@commitlint/config-conventional": "^19.1.0",
    "@size-limit/preset-small-lib": "^11.1.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/react-helmet-async": "^1.0.3",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "autoprefixer": "^10.4.21",
    "axe-core": "^4.8.4",
    "commitlint": "^19.2.1",
    "cross-env": "^7.0.3",
    "cspell": "^8.6.0",
    "depcheck": "^1.4.7",
    "eslint": "^8.57.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.1",
    "gh-pages": "^6.3.0",
    "husky": "^9.0.11",
    "jest-html-reporter": "^3.1.5",
    "jest-junit": "^16.0.0",
    "license-checker": "^25.0.1",
    "lint-staged": "^15.2.2",
    "markdownlint-cli": "^0.38.0",
    "npm-run-all": "^4.1.5",
    "nyc": "^15.1.0",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "rimraf": "^5.0.5",
    "sharp": "^0.34.3",
    "sharp-ico": "^0.1.5",
    "size-limit": "^11.1.4",
    "svgo": "^4.0.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.1.2",
    "typescript-eslint": "^8.38.0",
    "webpack-bundle-analyzer": "^4.10.1"
  }
}
