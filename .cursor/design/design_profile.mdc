## Примеры реализации с художественным подходом

### Hero Section (COSMOS) как эпическое полотно
```typescript
// Компонент с параллакс-эффектом и анимированными узлами как живая картина
const HeroSection: React.FC<HeroSectionProps> = ({ stats, title, description }) => {
  const parallaxRef = useRef<HTMLDivElement>(null);
  
  // Параллакс-эффект при скролле как движение в пространстве
  useEffect(() => {
    const handleParallax = () => {
      if (parallaxRef.current) {
        const scrolled = window.pageYOffset;
        const rate = scrolled * -0.5;
        parallaxRef.current.style.transform = `translateY(${rate}px)`;
      }
    };
    window.addEventListener('scroll', handleParallax);
    return () => window.removeEventListener('scroll', handleParallax);
  }, []);

  return (
    <section className="relative min-h-screen flex items-center justify-center overflow-hidden cosmic-bg">
      {/* Анимированные фоновые элементы как декорации */}
      <div className="absolute inset-0 cosmic-grid opacity-20"></div>
      <div className="absolute inset-0 floating-stars"></div>
      
      {/* Параллакс-слой как глубина картины */}
      <div ref={parallaxRef} className="absolute inset-0 cosmic-mesh-bg opacity-30"></div>
      
      {/* Контент как главные герои */}
      <div className="relative z-10 max-w-6xl mx-auto px-4 text-center">
        <h1 className="text-tasa-hero font-tasa text-white gradient-text">
          {title}
        </h1>
        {/* ... остальной контент как развитие сюжета */}
      </div>
    </section>
  );
};
```

